# Northstar Quant 环境变量示例
NORTHSTAR_ENV=dev
NORTHSTAR_TIMEZONE=Asia/Shanghai
NORTHSTAR_DEFAULT_PROFILE_ID=cn_etf_daily
NORTHSTAR_STORAGE_DIR=storage
NORTHSTAR_REPORTS_DIR=reports
NORTHSTAR_DATABASE_URL=sqlite:///storage/northstar.db

# broker: paper / ibkr
NORTHSTAR_BROKER=paper
NORTHSTAR_LIVE_TRADING_ENABLED=false
NORTHSTAR_KILL_SWITCH_ENABLED=false
NORTHSTAR_DEFAULT_CASH=100000
NORTHSTAR_REBALANCE_MIN_TRADE_VALUE=500

# IBKR
NORTHSTAR_IBKR_HOST=127.0.0.1
NORTHSTAR_IBKR_PORT=7497
NORTHSTAR_IBKR_CLIENT_ID=7
NORTHSTAR_IBKR_ACCOUNT=
NORTHSTAR_IBKR_READONLY=false

# 告警模式：console / wecom / telegram
NORTHSTAR_ALERT_MODE=console
NORTHSTAR_WECOM_WEBHOOK=
NORTHSTAR_WECOM_MENTIONED_MOBILE_LIST=
NORTHSTAR_TELEGRAM_BOT_TOKEN=
NORTHSTAR_TELEGRAM_CHAT_ID=
NORTHSTAR_TELEGRAM_MESSAGE_THREAD_ID=

# 邮件报告
NORTHSTAR_SMTP_HOST=
NORTHSTAR_SMTP_PORT=465
NORTHSTAR_SMTP_USERNAME=
NORTHSTAR_SMTP_PASSWORD=
NORTHSTAR_SMTP_SENDER=
NORTHSTAR_SMTP_USE_SSL=true
NORTHSTAR_REPORT_RECIPIENTS=

# 订单超时撤单
NORTHSTAR_ORDER_TIMEOUT_SECONDS=300
NORTHSTAR_LIMIT_PRICE_OFFSET_BPS=15
NORTHSTAR_LIMIT_CHASE_MAX_STEPS=3
NORTHSTAR_LIMIT_CHASE_SLEEP_SECONDS=2
NORTHSTAR_EXCHANGE_CALENDAR=XSHG
NORTHSTAR_SCHEDULER_TIMEZONE=Asia/Shanghai
NORTHSTAR_REPORT_BENCHMARK_SYMBOL=510300.SS
NORTHSTAR_TRADING_CURRENCY=CNY
NORTHSTAR_DASHBOARD_HOST=127.0.0.1
NORTHSTAR_DASHBOARD_PORT=8501

# 限价单追价执行器配置
NORTHSTAR_LIMIT_CHASE_PER_STEP_TIMEOUT_SECONDS=20
NORTHSTAR_LIMIT_CHASE_FALLBACK_MODE=market

# 报告邮件主题前缀（可选）
NORTHSTAR_REPORT_EMAIL_SUBJECT_PREFIX=Northstar Quant

# 邮件报告是否默认自动附加 PDF
NORTHSTAR_REPORT_EMAIL_ATTACH_PDF=true
